# ── DRiX Recruit — environment ────────────────────────────────────────────────
# Copy to .env and fill in. Nothing is hardcoded — the model is chosen here.

# Server
PORT=3002
APP_URL=http://localhost:3002

# LLM (OpenRouter) — swap the model any time; the app never hardcodes one.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4

# ── TDE (shared decomposition engine) ─────────────────────────────────────────
# Recruit ingests every URL through TDE's native recruit lens (decompose once,
# cache forever — the cross-product moat). If unset or unreachable, ingest falls
# back to the local brain path automatically, so the app keeps working.
TDE_BASE_URL=https://targeteddecomposition-production.up.railway.app
TDE_API_KEY=
# Max wait (ms) for a cold TDE ingest before falling back — the recruit lens is slow.
TDE_POLL_MAX_MS=360000

# Fit gate (score below this stops before strategies; the UI offers an override)
GATE_THRESHOLD=60

# Database — its OWN Railway Postgres, separate from DRiX Ready Leads.
# Leave blank to run in-memory (no persistence; good for a quick local smoke test).
DATABASE_URL=

# Central DRiX Auth (WinTech-Pay). Same service all DRiX apps use.
DRIX_AUTH_URL=https://wintech-pay-production.up.railway.app
SESSION_COOKIE_NAME=drix_session
COOKIE_DOMAIN=
WINTECH_PAY_APP_ID=
WINTECH_PAY_APP_KEY=
DRIX_PRICE_ID=
# Emails allowed to bypass the business-email rule (comma-separated).
ALLOWLIST_EMAILS=
ADMIN_EMAIL=
UNLIMITED_DOMAIN=wintechpartners.com
FREE_RUNS=3

# ── LOCAL DEV ONLY ────────────────────────────────────────────────────────────
# Skip the auth wall + metering so you can test without the central service
# minting a cookie. NEVER set this in production.
RECRUIT_DEV_OPEN=false
RECRUIT_DEV_EMAIL=dev@wintechpartners.com

# Optional richer scraping (JS-rendering). Without it, basic HTML fetch is used.
FIRECRAWL_API_KEY=

# ── Voice coach (ElevenLabs Conversational AI) ────────────────────────────────
ELEVENLABS_API_KEY=
RECRUIT_VOICE_ID=
ELEVEN_AGENT_LLM=gpt-4o
# Set this as the ElevenLabs post-call webhook secret to verify the transcript
# webhook that feeds voice turns into the shared chat↔voice memory.
ELEVENLABS_WEBHOOK_SECRET=
